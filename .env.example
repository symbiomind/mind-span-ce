# mind-span-ce environment config
# Copy to .env and fill in your values

# --- Identity tokens ---
# One token per identity defined in config.yml — these are what clients present as API keys
CRABBY_MARTIN=your-token-here
LYRA_MARTIN=your-token-here
MINISTRAL_MARTIN=your-token-here
OPENROUTER_TOKEN=your-token-here

# --- Upstream API keys ---
OPENCLAW_API_KEY=your-openclaw-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# --- Memory MCP resource token ---
# Token for the memory-mcp-ce instance declared as a resource in config.yml
MEMORY_MCP_TOKEN=your-memory-mcp-token-here

# --- Logging ---
LOG_LEVEL=INFO
LOG_REQUESTS=true
REQUEST_LOG_FILE=/app/logs/requests.jsonl

# --- Server ---
PORT=5005
