# mind-span-ce environment config
# Copy to .env and adjust

# Where to forward requests (Ollama, OpenRouter, OpenClaw, etc.)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama

# Logging
LOG_LEVEL=INFO
LOG_REQUESTS=true
REQUEST_LOG_FILE=/app/logs/requests.jsonl

# Client mode — controls context stripping behaviour
# Options: raw (no stripping), librechat, openwebui
CLIENT_MODE=raw

# Server
PORT=5005
